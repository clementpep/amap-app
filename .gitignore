# disabled by default.
# .vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment / secrets — NEVER commit these
.env
.env.local
.env.production
lib/core/config/secrets.dart
google-services.json
GoogleService-Info.plist

# Generated files (commit the .dart_tool/flutter_gen if you use it)
# lib/**/*.freezed.dart  # Some teams commit these, some don't
# lib/**/*.g.dart

# Coverage
coverage/
